# datasight configuration
# See: https://datasight.readthedocs.io/en/latest/configuration.html

# LLM provider: "anthropic" (default), "openai", "ollama", or "github"
# LLM_PROVIDER=anthropic

# --- Anthropic settings (when LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=your-api-key-here
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Optional: Azure AI Foundry endpoint
# ANTHROPIC_BASE_URL=https://your-resource.services.ai.azure.com/anthropic
# ANTHROPIC_FOUNDRY_RESOURCE=your-resource-name

# --- OpenAI settings (when LLM_PROVIDER=openai) ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# Override for Azure OpenAI or a corporate gateway:
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Ollama settings (when LLM_PROVIDER=ollama) ---
# Requires: pip install "datasight[ollama] @ git+https://github.com/dsgrid/datasight.git"
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen3:8b

# --- GitHub Models settings (when LLM_PROVIDER=github) ---
# Uses your GitHub token for authentication with GitHub Models.
# Requires: pip install "datasight[github] @ git+https://github.com/dsgrid/datasight.git"
# GITHUB_TOKEN=ghp_your-token-here
# GITHUB_MODELS_MODEL=gpt-4o
# GITHUB_MODELS_BASE_URL=https://models.github.ai/inference

# Database mode: "duckdb" (default), "sqlite", "postgres", or "flightsql"
DB_MODE=duckdb

# DuckDB settings (DB_MODE=duckdb)
DB_PATH=./my_database.duckdb

# SQLite settings (DB_MODE=sqlite)
# DB_PATH=./my_database.sqlite

# PostgreSQL settings (DB_MODE=postgres)
# Use individual fields or a connection URL (URL takes precedence).
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DATABASE=mydb
# POSTGRES_USER=datasight
# POSTGRES_PASSWORD=secret
# POSTGRES_SSLMODE=prefer
# Or use a connection string:
# POSTGRES_URL=postgresql://user:pass@host:5432/dbname

# Flight SQL settings (DB_MODE=flightsql)
# FLIGHT_SQL_URI=grpc://localhost:31337
# FLIGHT_SQL_TOKEN=
# FLIGHT_SQL_USERNAME=
# FLIGHT_SQL_PASSWORD=

# Optional: paths to context files for the AI agent.
# These are always local paths on the machine running datasight, even when
# connecting to a remote database via Flight SQL.
# SCHEMA_DESCRIPTION_PATH=./schema_description.md
# EXAMPLE_QUERIES_PATH=./queries.yaml

# Web UI port (default: 8084)
# PORT=8084

# Query behavior toggles
# CONFIRM_SQL=false
# EXPLAIN_SQL=false
# CLARIFY_SQL=true
# SHOW_PROVENANCE=false

# Output-token budget per LLM call (default: 4096)
# MAX_OUTPUT_TOKENS=4096

# LLM request timeout in seconds (default: 120)
# LLM_TIMEOUT=120
