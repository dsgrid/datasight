<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{html_title}}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<script src="{{plotly_cdn}}"></script>
<script src="{{marked_cdn}}"></script>
<script src="{{dompurify_cdn}}"></script>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    background: #f8f9fa; color: #1a1a2e;
    padding: 24px;
    line-height: 1.6;
  }
  h1 {
    font-size: 1.5rem; font-weight: 600; margin-bottom: 20px;
    padding-bottom: 12px; border-bottom: 2px solid #15a8a8;
    color: #15a8a8;
  }
  .dashboard-grid {
    display: grid;
    grid-template-columns: repeat({{columns}}, 1fr);
    gap: 16px;
  }
  @media (max-width: 900px) {
    .dashboard-grid { grid-template-columns: 1fr; }
  }
  .dashboard-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .card-title {
    padding: 12px 16px 8px;
    font-size: 0.85rem;
    font-weight: 500;
    color: #666;
    border-bottom: 1px solid #f0f0f0;
  }
  .chart-container {
    height: 400px;
    width: 100%;
  }
  .table-container {
    overflow-x: auto;
    padding: 8px;
  }
  .table-container table {
    width: 100%; border-collapse: collapse; font-size: 0.85rem;
  }
  .table-container th {
    background: #f1f3f5; padding: 8px 12px; text-align: left;
    font-weight: 600; border-bottom: 2px solid #dee2e6;
  }
  .table-container td {
    padding: 6px 12px; border-bottom: 1px solid #e5e7eb;
  }
  .table-container tr:hover td { background: #f8f9fa; }
  .table-toolbar, .table-pagination { display: none; }
  .source-details {
    margin: 0 12px 12px;
    border: 1px solid #dbe4ea;
    border-radius: 10px;
    background: #f9fbfc;
  }
  .source-details summary {
    cursor: pointer;
    padding: 10px 12px;
    font-size: 0.8rem;
    font-weight: 600;
    color: #315164;
  }
  .source-meta {
    display: grid;
    gap: 6px;
    padding: 0 12px 12px;
    font-size: 0.8rem;
  }
  .source-row {
    display: grid;
    grid-template-columns: 88px 1fr;
    gap: 10px;
  }
  .source-row strong {
    color: #6b7b88;
  }
  .source-sql {
    margin-top: 8px;
    padding: 10px 12px;
    border-radius: 8px;
    background: #10212b;
    color: #ecf5fa;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.74rem;
    white-space: pre-wrap;
    overflow-x: auto;
  }
  .source-error {
    margin-top: 8px;
    padding: 10px 12px;
    border-radius: 8px;
    background: #fff1f1;
    color: #9b1c1c;
  }
  .note-container {
    padding: 16px 18px;
  }
  .dashboard-section {
    grid-column: 1 / -1;
    padding: 16px 20px 14px;
    border: 1px dashed #bcd6d6;
    border-radius: 12px;
    background: linear-gradient(180deg, #edf9f8 0%, white 100%);
    overflow: hidden;
  }
  .section-body h1, .section-body h2, .section-body h3 {
    margin: 0 0 8px;
    color: #023d60;
    line-height: 1.2;
  }
  .section-body p { margin: 0 0 10px; color: #3b4a56; }
  .section-body ul, .section-body ol { margin: 0 0 10px 22px; color: #3b4a56; }
  .note-body {
    color: #24323d;
  }
  .note-body h1, .note-body h2, .note-body h3 {
    margin: 0 0 10px;
    color: #023d60;
    line-height: 1.25;
  }
  .note-body p { margin: 0 0 10px; }
  .note-body ul, .note-body ol { margin: 0 0 10px 22px; }
  .note-body code {
    background: #f1f3f5;
    border-radius: 4px;
    padding: 1px 5px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9em;
  }
  iframe {
    width: 100%; height: 400px; border: none;
  }
  .footer {
    margin-top: 24px; padding-top: 16px; border-top: 1px solid #dee2e6;
    font-size: 0.8rem; color: #999; text-align: center;
  }
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    margin: -8px 0 16px;
    padding: 10px 12px;
    background: #f1f7f7;
    border: 1px solid #d7e8e8;
    border-radius: 10px;
    font-size: 0.8rem;
    color: #315164;
  }
  .filter-bar-label {
    font-weight: 600;
    color: #023d60;
    margin-right: 2px;
  }
  .filter-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 3px 10px;
    background: white;
    border: 1px solid #bcd6d6;
    border-radius: 999px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
  }
  .filter-chip .op { color: #15a8a8; font-weight: 600; }
  .filter-chip .scope { color: #6b7b88; font-weight: 400; }
  .filter-bar-note {
    margin-left: auto;
    font-size: 0.72rem;
    color: #6b7b88;
    font-style: italic;
  }
</style>
</head>
<body>
{{#has_title}}<h1>{{title}}</h1>{{/has_title}}
{{#has_filters}}
<div class="filter-bar">
  <span class="filter-bar-label">Filters:</span>
  {{#filter_chips}}
  <span class="filter-chip">{{column}} <span class="op">{{operator}}</span> {{value}}{{#has_scope}} <span class="scope">· {{scope}}</span>{{/has_scope}}</span>
  {{/filter_chips}}
  <span class="filter-bar-note">Applied post-aggregation</span>
</div>
{{/has_filters}}
<div class="dashboard-grid">
{{#cards}}
{{#is_section}}
<div class="dashboard-section">
  <div class="section-body" data-markdown="{{{markdown}}}"></div>
</div>
{{/is_section}}
{{^is_section}}
<div class="dashboard-card">
{{#card_title}}<div class="card-title">{{card_title}}</div>{{/card_title}}
{{#is_chart}}<div class="chart-container" id="chart-{{idx}}"></div>{{/is_chart}}
{{#is_iframe}}<iframe sandbox="allow-scripts allow-same-origin" srcdoc="{{{html}}}"></iframe>{{/is_iframe}}
{{#is_table}}<div class="table-container">{{{html}}}</div>{{/is_table}}
{{#is_note}}<div class="note-container"><div class="note-body" data-markdown="{{{markdown}}}"></div></div>{{/is_note}}
{{#has_source_meta}}
<details class="source-details">
  <summary>Source</summary>
  <div class="source-meta">
    {{#source_rows}}
    <div class="source-row"><strong>{{label}}</strong><span>{{value}}</span></div>
    {{/source_rows}}
    {{#source_sql}}<pre class="source-sql">{{source_sql}}</pre>{{/source_sql}}
    {{#source_error}}<div class="source-error">{{source_error}}</div>{{/source_error}}
  </div>
</details>
{{/has_source_meta}}
</div>
{{/is_section}}
{{/cards}}
</div>
<div class="footer">Exported from datasight</div>
<script>
  var chartSpecs = {{{chart_specs_json}}};
  chartSpecs.forEach(function(item) {
    var spec = item.spec;
    var data = spec.data || [];
    var layout = Object.assign({}, spec.layout || {}, {
      autosize: true,
      height: undefined,
      paper_bgcolor: 'white',
      plot_bgcolor: 'white',
      font: { color: '#1a1a1a' },
      xaxis: Object.assign(spec.layout && spec.layout.xaxis || {}, {
        gridcolor: '#eee', linecolor: '#ddd', zerolinecolor: '#ddd'
      }),
      yaxis: Object.assign(spec.layout && spec.layout.yaxis || {}, {
        gridcolor: '#eee', linecolor: '#ddd', zerolinecolor: '#ddd'
      })
    });
    Plotly.newPlot('chart-' + item.idx, data, layout, {
      responsive: true,
      displayModeBar: true,
      modeBarButtonsToRemove: ['lasso2d', 'select2d'],
      displaylogo: false
    });
  });

  document.querySelectorAll('.note-body[data-markdown]').forEach(function(el) {
    var markdown = el.getAttribute('data-markdown') || '';
    el.innerHTML = DOMPurify.sanitize(marked.parse(markdown));
  });
  document.querySelectorAll('.section-body[data-markdown]').forEach(function(el) {
    var markdown = el.getAttribute('data-markdown') || '';
    el.innerHTML = DOMPurify.sanitize(marked.parse(markdown));
  });
</script>
</body>
</html>
